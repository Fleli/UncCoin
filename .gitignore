.venv/
.DS_Store
__pycache__/
*.py[cod]
*$py.class

# Native miner builds are platform/Python-version specific.
native_pow*.so
native_pow*.pyd
native_pow*.dll
native_pow*.dylib

# Local state snapshots and runtime data.
__*old_state/
state/wallets/*
!state/wallets/.gitkeep
state/blockchains/*
!state/blockchains/.gitkeep
state/msgs/*
!state/msgs/.gitkeep
state/aliases/*
!state/aliases/.gitkeep
state/contracts/
state/deleted/
state/desktop/
state/mining_tuning.json

# Local generated scripts.
scripts/run_auto.sh
scripts/run_auto_parallel.sh

# IDE/editor files.
/.idea/

# Runtime scratch files.
*.txt
!requirements*.txt
